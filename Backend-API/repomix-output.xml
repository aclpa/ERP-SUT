        assert service_response.status_code == 201
        service = service_response.json()
        service_id = service["id"]

        # 3. Deploy version 1.0.0
        deployment1_data = {
            "service_id": service_id,
            "version": "1.0.0",
            "environment": "production",
            "type": "manual",
            "status": "pending",
