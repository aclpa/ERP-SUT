            </q-card-section>
          </q-card>
        </div>
      </div>

      <!-- Days Remaining -->
      <div v-if="daysRemaining !== null" class="q-mt-md text-center">
        <q-chip
          :color="daysRemaining > 3 ? 'positive' : 'warning'"
          text-color="white"
          icon="event"
        >
          {{ daysRemaining }} days remaining
