function handleClick() {
  emit('click', props.sprint);
}

function handleEdit() {
  emit('edit', props.sprint);
}

function handleDelete() {
  emit('delete', props.sprint);
}

function handleStart() {
  emit('start', props.sprint);
}

function handleComplete() {
