  function setPageSize(size: number) {
    pageSize.value = size;
    currentPage.value = 1;
  }

  /**
   * Clear filters
   */
  function clearFilters() {
    searchQuery.value = '';
    serviceFilter.value = null;
    environmentFilter.value = '';
    typeFilter.value = '';
    statusFilter.value = '';
    currentPage.value = 1;
  }

  /**
